APP_NAME='GoTrip'
APP_ENV=local
APP_VERSION=1.2.2
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
APP_TIMEZONE=Asia/Kolkata

LOG_CHANNEL=stack
LOG_LEVEL=debug

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Nomod Hosted Checkout
NOMOD_API_KEY=your_nomod_api_key_here
NOMOD_BASE_URL=https://api.nomod.com
NOMOD_SUCCESS_URL=http://localhost/payment/nomod/success
NOMOD_FAILURE_URL=http://localhost/payment/nomod/failure
NOMOD_CANCELLED_URL=http://localhost/payment/nomod/cancelled

# Fluxir e-Visa (Global Travel Compliance) API
FLUXIR_AUTH_URL=https://auth.fluxir.com
FLUXIR_API_URL=https://api.fluxir.com
FLUXIR_TENANT_ID=
FLUXIR_CLIENT_ID=
FLUXIR_CLIENT_SECRET=
FLUXIR_SCOPE=TravelAideAPI
FLUXIR_GRANT_TYPE=client_credentials
FLUXIR_TOKEN_TTL=43200
FLUXIR_SUCCESS_URL=https://gotrips.ai/visa/fluxir/success
FLUXIR_CANCEL_URL=https://gotrips.ai/visa/fluxir/cancel
FLUXIR_STRIPE_PUBLISHABLE_KEY=
FLUXIR_SERVICE_TYPE=Visa
FLUXIR_DEFAULT_DESTINATION=ARE
FLUXIR_TIMEOUT=45
FLUXIR_DEBUG=false

# Farenexus nexusAPI (Flight GDS + NDC)
# Gateway + auth (obtain from Farenexus partner onboarding)
NEXUSAPI_BASE_URL=https://api.farenexus.com
NEXUSAPI_ENV=test
NEXUSAPI_KEY=
NEXUSAPI_SECRET=
NEXUSAPI_USERNAME=
NEXUSAPI_PASSWORD=
NEXUSAPI_TOKEN_TTL=840
# GDS session (Travelport/Galileo 1G — GoLite IATA). Values issued per the
# onboarding email; set the real ones here, never commit them.
NEXUSAPI_GDS_PROVIDER=1G
NEXUSAPI_PCC=
NEXUSAPI_TARGET_BRANCH=
NEXUSAPI_GDS_USERNAME=
NEXUSAPI_GDS_PASSWORD=
NEXUSAPI_GPM_CLIENT_ID=
NEXUSAPI_ACCREDITATION=GoLite
NEXUSAPI_DEVICE_TKT=
NEXUSAPI_DEVICE_ITN=
NEXUSAPI_DEVICE_MIR=
# Branch PCCs per market
NEXUSAPI_PCC_UAE=
NEXUSAPI_PCC_INDIA=
NEXUSAPI_PCC_CANADA=
NEXUSAPI_PCC_USA=
NEXUSAPI_PCC_SVCB=
NEXUSAPI_DEFAULT_BRANCH=uae
# Commercials
NEXUSAPI_MARKUP_PERCENT=0
NEXUSAPI_DEFAULT_CURRENCY=AED
NEXUSAPI_TIMEOUT=45
NEXUSAPI_DEBUG=false

# Mail Configuration
MAIL_MAILER=smtp
MAIL_HOST=your_mail_host_here
MAIL_PORT=465
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_mail_password_here
MAIL_FROM_ADDRESS=your_email@example.com
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Live football/FIFA scores — API-Football (api-sports.io).
# Free tier: live scores + FIFA World Cup, 100 requests/day. Get a key (free,
# no card) at https://dashboard.api-football.com and paste it below.
FOOTBALL_API_KEY=
FOOTBALL_API_BASE=https://v3.football.api-sports.io
FOOTBALL_WC_LEAGUE_ID=1
FOOTBALL_WC_SEASON=2026

# Database (Update the path below to match your project location)
# Windows: DB_DATABASE=C:\Users\YourName\Projects\Gotripes--main\database\database.sqlite
# Mac: DB_DATABASE=/Users/YourName/Projects/Gotripes--main/database/database.sqlite
DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite
