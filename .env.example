APP_NAME='GoTrip'
APP_ENV=local
APP_VERSION=1.2.2
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
APP_TIMEZONE=Asia/Kolkata

LOG_CHANNEL=stack
LOG_LEVEL=debug

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Nomod Hosted Checkout
NOMOD_API_KEY=your_nomod_api_key_here
NOMOD_BASE_URL=https://api.nomod.com
NOMOD_SUCCESS_URL=http://localhost/payment/nomod/success
NOMOD_FAILURE_URL=http://localhost/payment/nomod/failure
NOMOD_CANCELLED_URL=http://localhost/payment/nomod/cancelled

# Mail Configuration
MAIL_MAILER=smtp
MAIL_HOST=your_mail_host_here
MAIL_PORT=465
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_mail_password_here
MAIL_FROM_ADDRESS=your_email@example.com
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Database (Update the path below to match your project location)
# Windows: DB_DATABASE=C:\Users\YourName\Projects\Gotripes--main\database\database.sqlite
# Mac: DB_DATABASE=/Users/YourName/Projects/Gotripes--main/database/database.sqlite
DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite
